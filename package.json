{
  "name": "kaizen",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "vite --host --port 5173",
    "dev:backend": "bun run --hot ./server/server.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "start": "npm-run-all --parallel start:frontend start:backend",
    "start:frontend": "npx serve dist -l 9999",
    "start:backend": "npx run ./server/server.ts",
    "preview": "vite preview --host --port 5173",
    "typegen:appwrite": "bun appwrite pull tables && bun run ./scripts/appwrite-typegen.ts",
    "typegen:chakra": "chakra typegen ./src/kumi-ui/theme.ts",
    "typegen-supabase": "npx supabase gen types typescript --project-id yifheosdpnrhllqykpon --schema public > ./src/api/supabase.types.ts",
    "generate-icons": "bash ./src/assets/icons.sh"
  },
  "dependencies": {
    "@auth/core": "0.37.0",
    "@base-ui/react": "^1.4.0",
    "@biomejs/biome": "^2.4.10",
    "@chakra-ui/react": "^3.35.0",
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hono/node-server": "^2.0.0",
    "@hono/zod-validator": "^0.7.6",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@lexical/react": "^0.35.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tabler/icons-react": "^3.41.0",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/react-query": "^5.97.0",
    "@tanstack/react-query-devtools": "^5.97.0",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/router-plugin": "^1.167.12",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@uidotdev/usehooks": "^2.4.1",
    "@vitejs/plugin-react": "^6.0.1",
    "appwrite": "^23.0.0",
    "appwrite-cli": "^16.0.0",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "hono": "^4.12.9",
    "json-server": "^1.0.0-beta.15",
    "lexical": "^0.35.0",
    "lighthouse": "^13.1.0",
    "lowdb": "^7.0.1",
    "lucide-react": "^1.7.0",
    "multer": "^2.1.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite-plugin-svgr": "^4.3.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "globals": "^16.3.0",
    "npm-run-all2": "^7.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.10",
    "vite-bundle-analyzer": "^1.2.1"
  }
}
